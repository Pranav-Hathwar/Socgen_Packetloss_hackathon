JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
# Groq (free tier, no credit card) — get key at: console.groq.com
# Vendor names/IDs are NEVER sent. Only risk scores/flags.
# Leave blank to run fully deterministic (no external API calls).
GROQ_API_KEY=
